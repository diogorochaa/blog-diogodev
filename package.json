{
  "name": "blog-diogodev",
  "version": "0.5.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --project tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0 --cache",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest --project=unit",
    "test:run": "vitest run --project=unit",
    "test:coverage": "vitest run --coverage --project=unit",
    "test:storybook:prepare": "sh ./scripts/prepare-storybook-browser-libs.sh",
    "test:storybook": "vitest --project=storybook",
    "test:storybook:run": "vitest run --project=storybook",
    "test:all": "vitest run --project=unit --project=storybook",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "verify": "npm run check && npm run test:run",
    "slicemachine": "start-slicemachine",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
