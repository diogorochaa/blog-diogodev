    "@types/react-dom": "19.2.3",
    "eslint-config-next": "16.1.6",
    "framer-motion": "12.35.2",
    "next": "16.1.6",
    "postcss": "8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.8.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
