# Copie para .env.local e preencha os valores:
#   cp .env.example .env.local
#
# Prismic > Settings > API & Security

PRISMIC_REPOSITORY_NAME=blog-diodev
PRISMIC_ACCESS_TOKEN=

# Secret do webhook POST /api/revalidate (Authorization: Bearer <secret>)
PRISMIC_WEBHOOK_SECRET=

# Canonical, Open Graph e Twitter Cards (obrigatorio em producao)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
